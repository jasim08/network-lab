    classDef yellow fill:#fff3cd,stroke:#ffc107,stroke-width:2px;
    classDef green fill:#d4edda,stroke:#28a745,stroke-width:2px;

    subgraph Problem3 [1. Broken Inheritance]
        direction TB
        Bird["🦅 Parent: Bird Class<br>Method: fly"]:::red
        Eagle["🦅 Child: Eagle<br>fly works"]:::green
        Ostrich["🦤 Child: Ostrich<br>fly throws ERROR!"]:::red
        
        Bird --> Eagle
        Bird --> Ostrich
    end

    Refactor3{{"⚡ REFACTORING<br>Fix Class Hierarchy"}}:::yellow
    Problem3 --> Refactor3

    subgraph Solution3 [2. Safe Substitution]
        direction TB
        BaseBird["🦤 Base: Bird Class<br>Method: eat"]:::green
        FlyingBird["🦅 Sub: Flying Bird<br>Method: eat + fly"]:::green
        NewOstrich["🦤 Sub: Ostrich<br>Method: eat only"]:::green
        
        BaseBird --> FlyingBird
        BaseBird --> NewOstrich
    end
    Refactor3 --> Solution3