    style Private_Subnet fill:#FFF3E0,stroke:#E65100,stroke-width:2px,color:#000000
    
    style User fill:#000000,stroke:#000000,color:#FFFFFF
    style VPN_Client fill:#7E57C2,stroke:#5E35B1,color:#FFFFFF
    style nginx fill:#1565C0,stroke:#0D47A1,color:#FFFFFF
    style vpn fill:#7E57C2,stroke:#5E35B1,color:#FFFFFF
    style backend fill:#E65100,stroke:#BF360C,color:#FFFFFF
    style postgres fill:#2E7D32,stroke:#1B5E20,color:#FFFFFF
    
