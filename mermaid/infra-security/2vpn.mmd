graph TD
    subgraph Host_Machine ["Host Machine - Public Internet"]
        User([User / Laptop])
        VPN_Client["OpenVPN Client App"]
    end

    subgraph VPC ["VPC - 10.0.0.0/16"]
        
        subgraph Public_Subnet ["Public Subnet - 10.0.1.0/24"]
            nginx["nginx_proxy<br>(10.0.1.x)"]
        end

        subgraph Private_Subnet ["Private Subnet - 10.0.2.0/24"]
            vpn["vpn_gateway<br>(10.0.2.z)"]
            backend["app_backend<br>(10.0.1.y & 10.0.2.x)"]
            postgres["postgres_db<br>(10.0.2.y)"]
        end

    end

    %% Web Traffic
    User -->|Port 8080 - HTTP| nginx
    nginx -->|Port 3000| backend
    backend -->|Port 5432| postgres

    %% Secure Tunnel Admin Traffic
    User --> VPN_Client
    VPN_Client ===>|Port 1194 - Encrypted UDP Tunnel| vpn
    vpn ---->|Direct Route to Private IP| postgres

